# key/.env

# SITE_ROOT_URLは公開されるサイトのドメインを指定します（末尾にスラッシュ不要）
# 例: https://example.com

# BASE_PATHはFlaskアプリのURLパスのベースです。
# サブフォルダに配置する場合はスラッシュで囲む（例：/myapp/）
# ルート直下の場合は / を指定してください

# Flask関連の環境変数設定
SITE_ROOT_URL=https://example.com
BASE_PATH=

# ログの詳細レベル（DEBUG, INFO, WARNING, ERRORなど）
LOG_LEVEL=DEBUG

# Flaskのセキュリティキー（CSRF保護やセッション暗号化に必要）
# 実運用では十分に複雑でランダムな文字列を指定してください
SECRET_KEY=your-very-secret-key-123456789
